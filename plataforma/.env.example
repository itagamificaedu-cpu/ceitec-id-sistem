# ITA TECNOLOGIA EDUCACIONAL — Variáveis de Ambiente
# Copie para .env e preencha antes de rodar

# SENHA MASTER do administrador (Prof. Genezio)
# Use algo forte! Ex: ITAmaster2025@Genezio!
MASTER_PASSWORD=MUDE_ISSO_ANTES_DE_SUBIR

# Chave secreta Django (gere com: python -c "import secrets; print(secrets.token_hex(50))")
DJANGO_SECRET_KEY=GERE_UMA_CHAVE_SECRETA_AQUI

# Ambiente
DEBUG=False
ALLOWED_HOSTS=itatecnologia.com.br,www.itatecnologia.com.br,localhost

# Banco de dados
DATABASE_URL=sqlite:///db.sqlite3
# Para PostgreSQL: DATABASE_URL=postgres://user:senha@host:5432/dbname

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=SEU_TOKEN_MP

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu@gmail.com
EMAIL_HOST_PASSWORD=senha_de_app_gmail

# SSO
SSO_TOKEN_EXPIRATION_HOURS=8
SSO_COOKIE_DOMAIN=.itatecnologia.com.br

# IA
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
