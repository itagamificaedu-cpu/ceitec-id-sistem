{
  "name": "ceitec-id-backend",
  "version": "1.0.0",
  "description": "Backend do CEITEC ID System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore '*.sqlite' --ignore '*.sqlite-shm' --ignore '*.sqlite-wal' --ignore 'uploads/*' server.js"
  },
  "nodemonConfig": {
    "ignore": [
      "*.sqlite",
      "*.sqlite-shm",
      "*.sqlite-wal",
      "uploads/*"
    ],
    "ext": "js,json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.7.4",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
